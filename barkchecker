# Logs system
log_msg() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

# GitHub connection test
check_github_access() {
    local test_url="$1"

    if command -v curl >/dev/null 2>&1; then
        curl -Is "$test_url" >/dev/null 2>&1
        return $?
    elif command -v wget >/dev/null 2>&1; then
        wget --spider -q "$test_url"
        return $?
    else
        return 2
    fi
}

# Download update from GitHub
download_with_progress() {
    local url="$1"
    local output="$2"

    if command -v curl >/dev/null 2>&1; then
        curl -fL# "$url" -o "$output"
        return $?
    elif command -v wget >/dev/null 2>&1; then
        wget --show-progress -q "$url" -O "$output"
        return $?
    else
        return 2
    fi
}

get_remote_text() {
    local url="$1"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" 2>/dev/null
        return $?
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- "$url" 2>/dev/null
        return $?
    else
        return 2
    fi
}

# Update program
update_program() {
    local remote_version
    local tmp_program="/tmp/barkchecker_update_program"
    local target_path

    remote_version="$(get_remote_text "$VERSION_URL")"

    if [[ -z "$remote_version" ]]; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} не удалось получить удалённую версию утилиты"
        else
            echo -e "${RED_BOLD}Error:${RESET} failed to fetch remote program version"
        fi
        return 1
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${WHITE_BOLD}Текущая версия утилиты:${RESET} $PROGRAM_VERSION"
        echo -e "${WHITE_BOLD}Последняя версия утилиты:${RESET} $remote_version"
    else
        echo -e "${WHITE_BOLD}Current program version:${RESET} $PROGRAM_VERSION"
        echo -e "${WHITE_BOLD}Latest program version:${RESET} $remote_version"
    fi

    if [[ "$PROGRAM_VERSION" == "$remote_version" ]]; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${GREEN_BOLD}Утилита уже обновлена.${RESET}"
        else
            echo -e "${GREEN_BOLD}Program is already up to date.${RESET}"
        fi
        return 0
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${CYAN_BOLD}Скачивание новой версии утилиты...${RESET}"
    else
        echo -e "${CYAN_BOLD}Downloading new program version...${RESET}"
    fi

    if ! download_with_progress "$PROGRAM_URL" "$tmp_program"; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} не удалось скачать утилиту"
        else
            echo -e "${RED_BOLD}Error:${RESET} failed to download program"
        fi
        return 1
    fi

    chmod +x "$tmp_program"
    target_path="$(command -v barkchecker 2>/dev/null)"

    if [[ -z "$target_path" ]]; then
        target_path="/usr/local/bin/barkchecker"
    fi

    if [[ "$target_path" == "$HOME/"* ]]; then
        mv "$tmp_program" "$target_path"
    else
        sudo mv "$tmp_program" "$target_path" || return 1
        sudo chmod +x "$target_path" || return 1
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${GREEN_BOLD}Утилита обновлена до версии $remote_version.${RESET}"
    else
        echo -e "${GREEN_BOLD}Program updated to version $remote_version.${RESET}"
    fi

    log_msg "[update] program updated to $remote_version"
    return 0
}

# Update DB
update_database() {
    local remote_db_version
    local tmp_sh_db="/tmp/barkchecker_update_sh.db"
    local tmp_bundle_db="/tmp/barkchecker_update_bundle.db"

    remote_db_version="$(get_remote_text "$DB_VERSION_URL")"

    if [[ -z "$remote_db_version" ]]; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} не удалось получить удалённую версию базы"
        else
            echo -e "${RED_BOLD}Error:${RESET} failed to fetch remote database version"
        fi
        return 1
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${WHITE_BOLD}Текущая версия базы:${RESET} $DB_VERSION"
        echo -e "${WHITE_BOLD}Последняя версия базы:${RESET} $remote_db_version"
    else
        echo -e "${WHITE_BOLD}Current database version:${RESET} $DB_VERSION"
        echo -e "${WHITE_BOLD}Latest database version:${RESET} $remote_db_version"
    fi

    if [[ "$DB_VERSION" == "$remote_db_version" ]]; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${GREEN_BOLD}База уже обновлена.${RESET}"
        else
            echo -e "${GREEN_BOLD}Database is already up to date.${RESET}"
        fi
        return 0
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${CYAN_BOLD}Скачивание новой базы sh.db...${RESET}"
    else
        echo -e "${CYAN_BOLD}Downloading new sh.db...${RESET}"
    fi

    if ! download_with_progress "$SH_DB_URL" "$tmp_sh_db"; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} не удалось скачать sh.db"
        else
            echo -e "${RED_BOLD}Error:${RESET} failed to download sh.db"
        fi
        return 1
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${CYAN_BOLD}Скачивание новой базы bundle.db...${RESET}"
    else
        echo -e "${CYAN_BOLD}Downloading new bundle.db...${RESET}"
    fi

    if ! download_with_progress "$BUNDLE_DB_URL" "$tmp_bundle_db"; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} не удалось скачать bundle.db"
        else
            echo -e "${RED_BOLD}Error:${RESET} failed to download bundle.db"
        fi
        return 1
    fi

    mv "$tmp_sh_db" "$SH_DB" || return 1
    mv "$tmp_bundle_db" "$BUNDLE_DB" || return 1

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${GREEN_BOLD}База обновлена до версии $remote_db_version.${RESET}"
    else
        echo -e "${GREEN_BOLD}Database updated to version $remote_db_version.${RESET}"
    fi

    log_msg "[update] database updated to $remote_db_version"
    DB_VERSION="$remote_db_version"
    return 0
}

# UPDATER!!!
update_all() {
    set_update_urls
    local update_failed=0

    echo ""

# fallback if beta empty or unavalible
if ! check_github_access "$VERSION_URL"; then
    if [[ "$CHANNEL" == "beta" ]]; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${YELLOW_BOLD}Beta канал пока пуст или недоступен, переключаемся на stable...${RESET}"
        else
            echo -e "${YELLOW_BOLD}Beta channel unavailable, falling back to stable...${RESET}"
        fi

        CHANNEL="stable"
        save_settings
        set_update_urls

        # re-check for stable
        if ! check_github_access "$VERSION_URL"; then
            if [[ "$LANGUAGE" == "ru" ]]; then
                echo -e "${RED_BOLD}Ошибка:${RESET} даже stable недоступен"
            else
                echo -e "${RED_BOLD}Error:${RESET} even stable is unavailable"
            fi
            return 1
        fi
    else
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} нет доступа к обновлениям"
        else
            echo -e "${RED_BOLD}Error:${RESET} cannot access updates"
        fi
        return 1
    fi
fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${CYAN_BOLD}Проверка обновлений...${RESET}"
    else
        echo -e "${CYAN_BOLD}Checking for updates...${RESET}"
    fi

    echo ""
    update_program || update_failed=1

    echo ""
    update_database || update_failed=1

    echo ""
    if [[ $update_failed -eq 0 ]]; then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${GREEN_BOLD}Обновление завершено.${RESET}"
        else
            echo -e "${GREEN_BOLD}Update complete.${RESET}"
        fi
    else
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${YELLOW_BOLD}Обновление завершено с ошибками.${RESET}"
        else
            echo -e "${YELLOW_BOLD}Update finished with errors.${RESET}"
        fi
    fi
}

