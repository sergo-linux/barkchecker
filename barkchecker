change_language() {
    echo ""

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${CYAN_BOLD}Смена языка${RESET}"
        echo ""
        echo "1) Русский"
        echo "2) English"
        echo ""
        read -p "Выбери язык (1-2): " choice

        case "$choice" in
            1)
                LANGUAGE="ru"
                echo -e "${GREEN_BOLD}Язык уже установлен: Русский${RESET}"
                ;;
            2)
                LANGUAGE="en"
                echo -e "${GREEN_BOLD}Язык успешно изменён: English${RESET}"
                ;;
            *)
                echo -e "${RED_BOLD}Ошибка:${RESET} неверный выбор"
                exit 1
                ;;
        esac
    else
        echo -e "${CYAN_BOLD}Language settings${RESET}"
        echo ""
        echo "1) Русский"
        echo "2) English"
        echo ""
        read -p "Choose language (1-2): " choice

        case "$choice" in
            1)
