select_target_file() {
    FILES=()

for f in *; do
    [[ ! -f "$f" ]] && continue

    # if .sh or .bundle
    if [[ "$f" == *.sh || "$f" == *.bundle ]]; then
        FILES+=("$f")
        continue
    fi

    # if without .sh, but this is shell-script
    if head -n 1 "$f" | grep -qE '^#!.*(bash|sh)'; then
        FILES+=("$f")
    fi
done

    if [[ ${#FILES[@]} -eq 0 ]]; then
        msg no_files - -
        exit 1
    fi

    if [[ ${#FILES[@]} -eq 1 ]]; then
        TARGET_FILE="${FILES[0]}"
        return
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${CYAN_BOLD}Найдено несколько файлов:${RESET}"
    else
        echo -e "${CYAN_BOLD}Multiple files found:${RESET}"
    fi

    for i in "${!FILES[@]}"; do
        echo "$((i+1))) ${FILES[$i]}"
    done

    echo ""
    if [[ "$LANGUAGE" == "ru" ]]; then
        read -p "Выбери файл: " FILE_CHOICE
    else
        read -p "Choose a file: " FILE_CHOICE
    fi

    if ! [[ "$FILE_CHOICE" =~ ^[0-9]+$ ]] || (( FILE_CHOICE < 1 || FILE_CHOICE > ${#FILES[@]} )); then
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} неверный выбор файла"
        else
            echo -e "${RED_BOLD}Error:${RESET} invalid file choice"
        fi
        exit 1
    fi

    TARGET_FILE="${FILES[$((FILE_CHOICE-1))]}"
}

# The most important part, scanner!
scan_with_db() {
    local target_file="$1"
    local database_file="$2"
    local scan_source="$3"
    local found_any=0
    local result_file="/tmp/barkchecker_matches.txt"

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${WHITE_BOLD}Файл:${RESET} $target_file"
    else
        echo -e "${WHITE_BOLD}File:${RESET} $target_file"
    fi

    msg check_file "$target_file" "$target_file"
    echo ""

    while IFS='|' read -r level category pattern; do
        [[ -z "$pattern" ]] && continue

        grep -nF "$pattern" "$scan_source" > "$result_file" 2>/dev/null

        if [[ -s "$result_file" ]]; then
            found_any=1

            while IFS= read -r match_line; do
                line_number="${match_line%%:*}"
                line_content="${match_line#*:}"

                case "$level" in
                    critical)
                        CRITICAL_FOUND=1
                        CRITICAL_DETAILS+=("$category|$pattern|$line_number|$line_content")
                        msg critical "Forbidden pattern detected" "Обнаружен запрещённый паттерн"
                         ;;
                    warning)
                        msg warning "Suspicious pattern detected" "Обнаружен подозрительный паттерн"
                        ;;
                    info)
                        msg ok "Informational pattern detected" "Обнаружен информационный паттерн"
                        ;;
                    *)
                        msg warning "Pattern detected" "Обнаружен паттерн"
                        ;;
                esac

                if [[ "$LANGUAGE" == "ru" ]]; then
                    echo -e "  ${WHITE_BOLD}Категория:${RESET} $category"
                    echo -e "  ${WHITE_BOLD}Паттерн:${RESET} $pattern"
                    echo -e "  ${WHITE_BOLD}Строка:${RESET} $line_number"
                    echo -e "  ${WHITE_BOLD}Содержимое:${RESET} $line_content"
                else
                    echo -e "  ${WHITE_BOLD}Category:${RESET} $category"
                    echo -e "  ${WHITE_BOLD}Pattern:${RESET} $pattern"
                    echo -e "  ${WHITE_BOLD}Line:${RESET} $line_number"
                    echo -e "  ${WHITE_BOLD}Content:${RESET} $line_content"
                fi

# --- ADDITIONAL CHECK curl/wget ---
if [[ "$pattern" == "curl" || "$pattern" == "wget" ]]; then
    url=$(echo "$line_content" | grep -oE 'https?://[^ ]+')

    if [[ -z "$url" ]]; then
        url="$line_content"
    fi

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "  ${CYAN_BOLD}Загрузка:${RESET} $url"
    else
        echo -e "  ${CYAN_BOLD}Download:${RESET} $url"
    fi
fi

# --- REALLY DANGEROUS: curl | bash ---
if [[ "$line_content" == *"curl"* && "$line_content" == *"| bash"* ]]; then
    CRITICAL_FOUND=1
    CRITICAL_DETAILS+=("execution|curl | bash|$line_number|$line_content")
    msg critical "Pipe execution detected" "Обнаружено выполнение через pipe (curl | bash)"
fi

                log_msg "[$level][$category] $pattern | line $line_number | $line_content"
                echo ""
            done < "$result_file"
        fi
    done < "$database_file"

    rm -f "$result_file"

    if [[ $found_any -eq 0 ]]; then
        msg ok "No suspicious patterns detected" "Подозрительные паттерны не обнаружены"
        log_msg "[ok] No suspicious patterns in $target_file"
    fi
}

scan_sh_file() {
    [[ ! -f "$SH_DB" ]] && {
        msg critical "sh.db not found" "Файл sh.db не найден"
        exit 1
    }
    local file="$1"
    scan_with_db "$file" "$SH_DB" "$file"
}

scan_bundle_file() {
    [[ ! -f "$BUNDLE_DB" ]] && {
        msg critical "bundle.db not found" "Файл bundle.db не найден"
        exit 1
    }
    local file="$1"
    local extracted="/tmp/barkchecker_bundle_strings.txt"

    strings "$file" > "$extracted" 2>/dev/null
    scan_with_db "$file" "$BUNDLE_DB" "$extracted"
    rm -f "$extracted"
}

run_scan() {
    select_target_file
    CRITICAL_FOUND=0
    CRITICAL_DETAILS=()

    if [[ "$TARGET_FILE" == *.bundle ]]; then
        scan_bundle_file "$TARGET_FILE"
    elif [[ "$TARGET_FILE" == *.sh ]] || head -n 1 "$TARGET_FILE" | grep -qE '^#!.*(bash|sh)'; then
        scan_sh_file "$TARGET_FILE"
    else
        if [[ "$LANGUAGE" == "ru" ]]; then
            echo -e "${RED_BOLD}Ошибка:${RESET} неподдерживаемый тип файла"
        else
            echo -e "${RED_BOLD}Error:${RESET} unsupported file type"
        fi
        exit 1
    fi

    if [[ $CRITICAL_FOUND -eq 1 ]]; then
        if confirm_quarantine; then
            quarantine_file "$TARGET_FILE"
        else
            if [[ "$LANGUAGE" == "ru" ]]; then
                echo -e "${YELLOW_BOLD}Файл оставлен на месте.${RESET}"
            else
                echo -e "${YELLOW_BOLD}File left in place.${RESET}"
            fi
        fi
    fi
}

show_first_run_welcome
run_scan
