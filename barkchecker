                echo -e "${GREEN_BOLD}Language changed: Russian${RESET}"
                ;;
            2)
                LANGUAGE="en"
                echo -e "${GREEN_BOLD}Language already set: English${RESET}"
                ;;
            *)
                echo -e "${RED_BOLD}Error:${RESET} invalid choice"
                exit 1
                ;;
        esac
    fi

    save_settings
    exit 0
}

confirm_quarantine() {
    while true; do
        echo ""

        if [[ "$LANGUAGE" == "ru" ]]; then
            count=${#CRITICAL_DETAILS[@]}
            echo -e "${RED_BOLD}Обнаружено критичных паттернов: $count${RESET}"

            read -p "Переместить файл в карантин? (д/н): " answer

            case "$answer" in
                д|Д)
                    return 0
                    ;;
                н|Н)
                    return 1
                    ;;
                *)
                    echo -e "${YELLOW_BOLD}Пожалуйста, введите только: д или н${RESET}"
                    ;;
            esac
        else
            echo -e "${RED_BOLD}Critical patterns detected: $count${RESET}"

            read -p "Move file to quarantine? (y/n): " answer

            case "$answer" in
                y|Y)
                    return 0
                    ;;
                n|N)
                    return 1
                    ;;
                *)
                    echo -e "${YELLOW_BOLD}Please enter only: y or n${RESET}"
                    ;;
            esac
        fi
    done
}

quarantine_file() {
    local file="$1"

    [[ ! -f "$file" ]] && return

    local base_name
    base_name="$(basename "$file")"

    local timestamp
    timestamp="$(date '+%Y%m%d_%H%M%S')"

    local target="$QUARANTINE_DIR/${timestamp}_${base_name}"

    mv "$file" "$target"

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo ""
        echo -e "${RED_BOLD}Файл перемещён в карантин.${RESET}"
        echo -e "${WHITE_BOLD}Новый путь:${RESET} $target"
    else
        echo ""
        echo -e "${RED_BOLD}File moved to quarantine.${RESET}"
        echo -e "${WHITE_BOLD}New path:${RESET} $target"
    fi

    log_msg "[quarantine] $file -> $target"
}

