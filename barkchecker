# msg function

msg() {
    KEY=$1            # word key (eg 'critical')
    EXTRA_EN=$2       # extra text on English
    EXTRA_RU=$3       # extra text on Russian

    # If recieved "-", means empty
    [[ "$EXTRA_EN" == "-" ]] && EXTRA_EN=""
    [[ "$EXTRA_RU" == "-" ]] && EXTRA_RU=""

    if [[ "$LANGUAGE" == "ru" ]]; then
        echo -e "${MSG_RU[$KEY]} ${EXTRA_RU}"
    else
        echo -e "${MSG_EN[$KEY]} ${EXTRA_EN}"
    fi
}

